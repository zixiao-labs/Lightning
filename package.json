{
  "name": "@lightning-js/lightning",
  "version": "0.0.1",
  "description": "Lightning A Next Generation Testing Framework - 比神霄派雷法还快的测试框架，让测试更简单！",
  "keywords": [
    "test",
    "jest-alternative"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/zixiao-labs/Lightning#readme",
  "bugs": {
    "url": "https://github.com/zixiao-labs/Lightning/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zixiao-labs/Lightning.git"
  },
  "license": "MIT",
  "author": "Zixiao Laboratories",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "lightning": "bin/lightning.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node bin/lightning.mjs run --root .",
    "test:playground": "pnpm build && node bin/lightning.mjs run --root playground/basic math.test strings.test",
    "test:demo:fail": "pnpm build && node bin/lightning.mjs run --root playground/basic"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "types": "^0.1.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nasti-toolchain/nasti": "^2.0.2",
    "cac": "^7.0.0",
    "tinyglobby": "^0.2.17",
    "tinyrainbow": "^3.1.0"
  }
}
